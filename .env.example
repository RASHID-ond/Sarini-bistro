# ── Backend (server.ts) — set these on Render ──────────────────────
PORT=3000
# Comma-separated list of allowed frontend origins for CORS.
# e.g. "https://sarini-bistro.vercel.app" or multiple: "https://a.com,https://b.com"
FRONTEND_URL="http://localhost:5173"
# Used to build the M-Pesa callback URL. Set to your Render URL in production.
APP_URL="http://localhost:3000"

# Supabase (Project Settings → API)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# Use the SERVICE ROLE key here (backend only — never expose this to the frontend)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Storage bucket name for uploaded images (create this bucket as Public in Supabase Storage)
SUPABASE_STORAGE_BUCKET="images"

# ── Frontend (Vite) — set this on Vercel ────────────────────────────
# URL of your deployed backend on Render
VITE_API_URL="http://localhost:3000"
